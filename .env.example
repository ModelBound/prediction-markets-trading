# Prediction Markets Trading Agent - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env or any file containing real keys/tokens.

# --- Required: Kalshi ---
KALSHI_API_KEY_ID=your-kalshi-api-key-id
# RSA private key on one line with literal \n for newlines:
KALSHI_API_RSA="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# --- Required: AI Provider ---
OPENAI_KEY=sk-your-openai-api-key

# --- Trading Mode ---
# "demo" uses Kalshi's sandbox (no real money). "production" trades real funds.
TRADING_MODE=demo

# --- Provider Selection ---
PREDICTION_MARKET_PROVIDER=kalshi
AI_PROVIDER=openai

# --- Research (web search for market analysis) ---
# "free" = Agent-Reach backends: Exa/mcporter + DuckDuckGo + Jina Reader (default, $0)
# "openai" = OpenAI web_search_preview (~$0.03/call)
RESEARCH_PROVIDER=free

# Exa semantic search via mcporter (installed in Docker; optional locally)
# EXA_MCP_URL=https://mcp.exa.ai/mcp?tools=web_search_exa
# EXA_SEARCH_ENABLED=true

# --- Dashboard remote sync (when agent runs on a droplet) ---
# DROPLET_IP=your.droplet.ip.address
# DROPLET_API_PORT=9090
# DROPLET_SSH_KEY=~/.ssh/id_rsa_digitalocean

# --- Optional: ModelBound (skill/prompt management) ---
# Pull trading prompts/skills from your ModelBound library into data/modelbound_cache.json
# MODELBOUND_API_TOKEN=mb_live_your-token-here
# MODELBOUND_API_KEY=mb_live_your-token-here   # alias (either var works)
# MODELBOUND_MCP_URL=https://mcp.modelbound.co/
# MODELBOUND_SKILL_REPO=Trading               # repo name filter when syncing via API
# MODELBOUND_AUTO_SYNC=false                  # set true on headless servers to refresh via API
# MODELBOUND_SYNC_MAX_AGE_HOURS=24

# --- Optional: DigitalOcean Deployment ---
# DIGITALOCEAN_TOKEN=dop_v1_your-token-here
# DIGITALOCEAN_SSH_KEY_ID=12345678

# --- Optional: Polymarket (scaffold - not production-ready) ---
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=
# POLYMARKET_FUND_ADDRESS=
