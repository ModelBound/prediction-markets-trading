# Trading mode
# Use demo until you understand the risk controls and have tested your setup.
TRADING_MODE=demo
PREDICTION_MARKET_PROVIDER=kalshi
AI_PROVIDER=openai

# Kalshi
# Create API credentials in your Kalshi account and paste the RSA private key as
# a single line with literal \n newlines, or export it in your shell/secret store.
KALSHI_API_KEY_ID=your_kalshi_api_key_id
KALSHI_API_RSA="paste_your_private_key_here_with_literal_newline_escapes"

# OpenAI
OPENAI_KEY=your_openai_api_key

# Optional ModelBound skill management
# The app can run without this. Use your own token if you sync ModelBound skills.
MODELBOUND_API_TOKEN=your_modelbound_token

# Optional Polymarket extension credentials
# The bundled Polymarket adapter is a scaffold for contributors.
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_PRIVATE_KEY=your_polymarket_private_key
POLYMARKET_FUNDER_ADDRESS=your_polymarket_funder_address

# Optional DigitalOcean deployment helpers
DIGITALOCEAN_TOKEN=your_digitalocean_token
DROPLET_IP=your_droplet_ip

# Optional GitHub publishing; never commit real tokens.
GITHUB_PAT=your_github_pat
